# Copy to .env and adjust. All settings are optional; defaults target a local
# Ollama instance and a laptop-class GPU.

# --- LLM provider (OpenAI-compatible endpoint) ---
# WATARI_LLM_BASE_URL=http://localhost:11434/v1
# WATARI_LLM_API_KEY=ollama

# --- Named model roles ---
# WATARI_CHAT_MODEL=qwen3.5:4b
# WATARI_JUDGE_MODEL=qwen3.5:4b
# WATARI_EXTRACT_MODEL=qwen3.5:4b
# WATARI_EMBED_MODEL=BAAI/bge-small-en-v1.5

# --- Generation ---
# Thinking control for reasoning models (Qwen 3.5 etc.):
# "none" disables the hidden chain of thought (fast, default); "low"/"medium"/
# "high" enable progressively more deliberation at the cost of latency/tokens.
# WATARI_REASONING_EFFORT=none
# WATARI_TEMPERATURE=0.7
# WATARI_MAX_CONTEXT_TOKENS=8192
# WATARI_MAX_RESPONSE_TOKENS=1024

# --- Server ---
# WATARI_HOST=127.0.0.1
# WATARI_PORT=8000

# --- Observability ---
# WATARI_LOG_LEVEL=INFO
# WATARI_LOG_JSON=false
